{
  "manifest_version": 3,
  "name": "Octo-Free React",
  "version": "11.0.0",
  "description": "Adds a file tree sidebar to GitHub repository pages. Browse files, switch branches, search by filename, and download files.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "src/background/serviceWorker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["src/content/index.tsx"]
    }
  ],
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  }
}
