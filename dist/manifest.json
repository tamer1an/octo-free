{
  "manifest_version": 3,
  "name": "Octo-Free",
  "version": "11.0.0",
  "description": "GitHub file tree sidebar with private repo support. Switch branches, search and download files from any repository.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-loader-Bs6-0JNu.js"
      ],
      "matches": [
        "https://github.com/*"
      ]
    }
  ],
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "resources": [
        "assets/github-BTWQDC2s.js",
        "assets/index.tsx-DS6CVKro.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
