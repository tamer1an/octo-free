{
  "manifest_version": 3,
  "name": "Octo-Free React",
  "version": "11.0.0",
  "description": "Adds a file tree sidebar to GitHub repository pages. Browse files, switch branches, search by filename, and download files.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-loader-DYGupgOT.js"
      ],
      "matches": [
        "https://github.com/*"
      ]
    }
  ],
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "resources": [
        "assets/github-BTWQDC2s.js",
        "assets/index.tsx-Dw-7enjJ.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
